# Tessellation Docker Environment Variables

# Build version for Docker images
BUILD_VERSION=0.0.1

# GL0 (Global Layer 0) Peer ID
# This ID is automatically generated during the first run, but you can set it manually if needed
# Example format: "123e4567-e89b-12d3-a456-426614174000"
L0_PEER_ID=

# GL0 collateral amount (optional, default: 0)
# CL_COLLATERAL=0

# Additional environment variables can be added below as needed
# Uncomment the desired variables:

# Custom keystores - if you want to use your own keystores
# CUSTOM_L0_KEYSTORE=path/to/l0-keystore.p12
# CUSTOM_L1_KEYSTORE=path/to/l1-keystore.p12

# Key alias and password - if you want to use custom values
# CL_KEYALIAS=alias
# CL_PASSWORD=password

# Application environment
# CL_APP_ENV=dev

# Java options
# JAVA_OPTS=-Dlogback.configurationFile=logback-kubernetes.xml -Dcats.effect.tracing.mode=full -Dcats.effect.tracing.buffer.size=64
